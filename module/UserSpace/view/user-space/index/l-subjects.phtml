<h1 class="mt-4">Unités d'enseignements attribués</h1>
   <ol class="breadcrumb mb-4">
       <li class="breadcrumb-item active">Tableau des attributions</li>
   </ol>




         
        <div  style="background-color: #dfe4ea;" >
            <div class="row">  
            <div ng-cloak  style="margin-top:25px;">

            <md-input-container class="column md-block" flex-gt-sm>
      
            <br />
                            <div flex-gt-sm flex="50">
                                <table class=" table table-bordered bordered table-striped table-condensed datatable" style="font-size:0.8em; background-color: #dfe4ea; color: #0c2461;" ui-jq="dataTable" ui-options="dataTableOpt">
                                    <thead>
                                        <tr style="background-color:#708090; text-align: center;">
                                        <th style="vertical-align: middle;" >#</th>
                                        <th style="vertical-align: middle;" >UE</th>
                                        <th style="vertical-align: middle;" >Sem</th>
                                        <th style="vertical-align: middle;" >Classe</th>
                                        <th style="vertical-align: middle;" >Volume Horaire</th>
                                        
                                    </tr>
                                    
                                    </thead>
                                    <tbody>
                                    <tr ng-repeat="teachingUnit in $ctrl.subjects" class="clickable teacher-item"
                                        ng-style="{'background-color': teachingUnit.id === selectedTeachingUnitId ? 'lightblue' : 'initial'}"
                                        ng-click="onSelectTeachingUnit(teachingUnit.id)">
                                        <td>{{$index+1}}</td>
                                        <td>{{teachingUnit.codeUe}}</td>
                                        <td>{{teachingUnit.semester}}</td>
                                        <td>{{teachingUnit.classe}}</td>
                                        <td>{{teachingUnit.totalHrs}}H</td>
                                        
                                       
                                    </tr>
                                    <tr style="text-align:center;font-weight : bold; color: #fff; background-color:#708090;"><td  colspan="4">Total Volume Horaire</td><td align="left">{{$ctrl.subjects|sumByKey:'totalHrs'}}H</td>
                                    
                                    </tr>
                                    </tbody>
                                </table>
                            </div>
            </md-input-container>

            </div>

        </div>
        </div>
           
 

                
 

